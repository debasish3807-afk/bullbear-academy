rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Profile pictures
    match /users/{userId}/avatar/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Course content (teachers and admins)
    match /courses/{courseId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && (get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'teacher'
                       || get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // Assignment submissions
    match /assignments/{userId}/{fileName} {
      allow read: if request.auth != null
                  && (request.auth.uid == userId
                      || get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['teacher', 'admin']);
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 20 * 1024 * 1024;
    }
  }
}
